NODE_ENV=development
PORT=5000

# PostgreSQL — local development
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=venue_booking
PG_USER=postgres
PG_PASSWORD=your_secure_password_here

# OR use a single connection URL (takes precedence, useful for cloud deploys)
# DATABASE_URL=postgresql://user:password@host:5432/venue_booking

# Railway deployment notes:
# - Set DATABASE_URL from Railway PostgreSQL service.
# - Railway sets PORT automatically.

JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
# Single or comma-separated frontend origins
CORS_ORIGIN=http://localhost:3000,http://192.168.116.1:3000,https://venue-booking-two.vercel.app,https://venue-booking-z528.vercel.app
